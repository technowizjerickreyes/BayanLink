{
  "name": "bayanlink",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "start": "npm run start --prefix server",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "check": "npm run check --prefix server",
    "seed:roles": "npm run seed:roles --prefix server",
    "seed:super-admin": "npm run seed:super-admin --prefix server",
    "seed:municipalities": "npm run seed:municipalities --prefix server",
    "seed:portal-users": "npm run seed:portal-users --prefix server",
    "seed:all": "npm run seed:roles && npm run seed:super-admin && npm run seed:municipalities && npm run seed:portal-users",
    "setup:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./setup-env.ps1",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "latest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "react": "^19.2.5",
    "react-router-dom": "^7.14.1"
  }
}
